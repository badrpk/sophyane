# Sophyane environment template (copy to ~/.config/sophyane/cloud_keys.env
# or export in your shell). Never commit real keys.

# Primary LLM (default after install / git clone)
GEMINI_API_KEY=your_gemini_api_key_here
# Optional alias accepted by Sophyane:
# GOOGLE_API_KEY=your_gemini_api_key_here

# Optional cloud fallbacks
# OPENAI_API_KEY=sk-...
# XAI_API_KEY=xai-...
# ANTHROPIC_API_KEY=...
# GROQ_API_KEY=...
# OPENROUTER_API_KEY=...
